{
    "name": "ielfran/phptypes-bridge",
    "description": "Generate TypeScript types, Zod schemas, and fetch clients from PHP APIs — zero YAML, zero drift",
    "type": "library",
    "license": "MIT",
    "keywords": ["typescript", "codegen", "php", "api", "zod", "dto", "openapi-alternative"],
    "authors": [
        {
            "name": "Ielfran",
            "email": "gaganrai.prog@gmail.com"
        }
    ],
    "require": {
        "php": "^8.1",
        "symfony/console": "^6.0|^7.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5",
        "phpstan/phpstan": "^1.10",
        "friendsofphp/php-cs-fixer": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "PHPTypeS\\Bridge\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "PHPTypeS\\Bridge\\Tests\\": "tests/"
        }
    },
    "bin": ["bin/bridge"],
    "scripts": {
        "test": "phpunit",
        "stan": "phpstan analyse src tests --level=8",
        "lint": "php-cs-fixer fix --dry-run --diff",
        "fix": "php-cs-fixer fix"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "php-http/discovery": true
        }
    },
    "minimum-stability": "stable"
}
